# Grafana Dashboard Configuration
# Import this JSON to Grafana for monitoring

{
  "dashboard": {
    "title": "翠花量化系统监控",
    "panels": [
      {
        "title": "系统 CPU 使用率",
        "type": "gauge",
        "targets": [{"expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"}]
      },
      {
        "title": "内存使用率",
        "type": "gauge",
        "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100"}]
      },
      {
        "title": "磁盘使用率",
        "type": "gauge",
        "targets": [{"expr": "(1 - (node_filesystem_avail_bytes / node_filesystem_size_bytes)) * 100"}]
      },
      {
        "title": "投资组合价值",
        "type": "graph",
        "targets": [{"expr": "cuihua_portfolio_value"}]
      },
      {
        "title": "每日盈亏",
        "type": "graph",
        "targets": [{"expr": "cuihua_daily_pnl"}]
      },
      {
        "title": "持仓数量",
        "type": "stat",
        "targets": [{"expr": "cuihua_position_count"}]
      }
    ]
  }
}
